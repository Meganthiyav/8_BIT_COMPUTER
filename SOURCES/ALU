module tb_alu;

reg [7:0] a_in;
reg [7:0] b_in;
reg [2:0] command_in;

wire [7:0] result;
wire carry_out;

alu dut(
    .a_in(a_in),
    .b_in(b_in),
    .command_in(command_in),
    .result(result),
    .carry_out(carry_out)
);

initial begin

    a_in = 8'd0;
    b_in = 8'd0;
    command_in = 3'd0;

    #10 a_in = 8'd10; b_in = 8'd5; command_in = 3'b000;
    #10 command_in = 3'b001;
    #10 command_in = 3'b010;
    #10 command_in = 3'b011;
    #10 command_in = 3'b100;
    #10 command_in = 3'b101;
    #10 command_in = 3'b110;
    #10 command_in = 3'b111;

    #10 a_in = 8'd255; b_in = 8'd1; command_in = 3'b000;
    #10 command_in = 3'b001;
    #10 command_in = 3'b010;
    #10 command_in = 3'b011;

    #20 $finish;

end
initial begin
    $display("TIME\tCMD\tA\tB\tRESULT\tCARRY");
    $monitor("%0t\t%b\t%d\t%d\t%d\t%b",
             $time, command_in, a_in, b_in, result, carry_out);
end

endmodule
                  
                 
                
                 
                     
          
