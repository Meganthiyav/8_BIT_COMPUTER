ALU:

• Developed an 8-bit FPGA-ready ALU in Verilog HDL.
• Implemented ADD, SUB, INC, DEC, AND, OR, XOR, and NOT operations.
• Designed carry flag generation for arithmetic instructions.
• Created a self-checking testbench and validated functionality using Vivado Simulator.

RTL CODE:
module alu(input [7:0] a_in,
           input [7:0] b_in,
           input [2:0] command_in,
           output reg [7:0] result,
           output reg carry_out);
           
          reg[8:0] temp;
always @(*) begin
          result = 8'b00000000;
          carry_out = 1'b0;
          temp = 9'b000000000;
          case(command_in)
          3'b000:begin //add
                 temp = a_in + b_in;
                 result = temp[7:0];
                 carry_out = temp[8];
                 end
          3'b001:begin //sub
                 temp = a_in - b_in;
                 result = temp[7:0];
                 carry_out = (a_in < b_in);
                 end
          3'b010:begin //inc
                 temp = a_in + 1'b1;
                 result = temp[7:0];
                 carry_out = temp[8];
                 end
          3'b011:begin //dec
                 temp = a_in - 1'b1;
                 result = temp[7:0];
                 carry_out = temp[8];
                 end
          
          3'b100:begin //and
                 result = a_in & b_in;
                 end
                
          3'b101:begin //or
                 result = a_in | b_in;
                 end
                 
          3'b110:begin //xor
                 result = a_in ^ b_in;
                 end
               
          3'b111:begin //not
                 result = ~a_in;
                 end
           
          default: begin
                  result = 8'b00000000;
                  carry_out = 1'b0;
                  end
          endcase
     end
  endmodule 



